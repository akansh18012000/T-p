# Terumo Environment Configuration
# Copy this to .env.local and fill in your Entra ID values

# Microsoft Entra ID (Azure AD) Configuration
VITE_MSAL_CLIENT_ID=your_client_id_from_azure_portal
VITE_MSAL_AUTHORITY=https://login.microsoftonline.com/your_tenant_id
VITE_MSAL_REDIRECT_URI=http://localhost:3000

# Optional: Additional API Configuration
# VITE_API_BASE_URL=http://localhost:5000/api
